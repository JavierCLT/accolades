# Core storage/runtime
DB_PATH=data/monitor.sqlite
LOG_LEVEL=INFO
LOG_FILE=
LOCAL_TIMEZONE=America/New_York
SEND_EMPTY_DIGEST=false
MAX_ITEMS_PER_DIGEST=30

# Google Custom Search JSON API
GOOGLE_CSE_API_KEY=replace-me
GOOGLE_CSE_ID=replace-me

# Email backend: smtp or gmail_api
EMAIL_BACKEND=smtp
EMAIL_FROM=alerts@example.com
EMAIL_TO=you@example.com

# SMTP option. For Gmail SMTP, use an app password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=replace-me
SMTP_STARTTLS=true

# Gmail API option. Token must include https://www.googleapis.com/auth/gmail.send.
# Set EMAIL_BACKEND=gmail_api and provide the full authorized-user token JSON.
GMAIL_TOKEN_JSON={"token":"...","refresh_token":"...","token_uri":"https://oauth2.googleapis.com/token","client_id":"...","client_secret":"...","scopes":["https://www.googleapis.com/auth/gmail.send"]}

# Optional LLM classification. If disabled or unavailable, rule-based classification is used.
LLM_CLASSIFIER_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=
